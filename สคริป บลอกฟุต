   Flag = "SearchItemInput",
   Callback = function(Text)
      local keyword = string.lower(Text)
      local foundMatch = nil
      
      local backpack = LocalPlayer:FindFirstChildOfClass("Backpack")
      local character = LocalPlayer.Character
      
      if backpack then
         for _, item in ipairs(backpack:GetChildren()) do
            if item:IsA("Tool") and string.find(string.lower(item.Name), keyword) then
               foundMatch = item.Name
               break
            end
         end
      end
      
      if not foundMatch and character then
         for _, item in ipairs(character:GetChildren()) do
            if item:IsA("Tool") and string.find(string.lower(item.Name), keyword) then
               foundMatch = item.Name
               break
            end
         end
      end
      
      if foundMatch then
         equipToolByName(foundMatch)
      else
         Rayfield:Notify({ Title = "ไม่พบ", Content = "ไม่พบไอเท็มที่มีคำว่า: " .. Text, Duration = 2 })
