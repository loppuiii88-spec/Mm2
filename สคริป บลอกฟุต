ItemTab:CreateLabel("ระบบสแกนไอเท็มในตัว (เลือกเลื่อนดูและกดหยิบได้ทันที)")

local function fetchItems()
   local list = {}
   local checked = {}
   local backpack = LocalPlayer:FindFirstChildOfClass("Backpack")
   local character = LocalPlayer.Character

   if backpack then
      for _, item in ipairs(backpack:GetChildren()) do
         if item:IsA("Tool") and not checked[item.Name] then
            checked[item.Name] = true
            table.insert(list, item.Name)
         end
      end
   end

   if character then
      for _, item in ipairs(character:GetChildren()) do
         if item:IsA("Tool") and not checked[item.Name] then
            checked[item.Name] = true
            table.insert(list, item.Name)
         end
      end
   end

   if #list == 0 then
      return {"(ไม่พบไอเท็มในกระเป๋า)"}
   end
   return list
end

allItemNames = fetchItems()

local function equipToolByName(targetName)
   if not targetName or targetName == "(ไม่พบไอเท็มในกระเป๋า)" then return end
   
   local character = LocalPlayer.Character
   local humanoid = character and character:FindFirstChildOfClass("Humanoid")
   local backpack = LocalPlayer:FindFirstChildOfClass("Backpack")
   
   if not character or not humanoid or not backpack then return end
   
   local targetTool = nil
   for _, item in ipairs(backpack:GetChildren()) do
      if item:IsA("Tool") and item.Name == targetName then
         targetTool = item
         break
      end
   end
   
   if targetTool then
      humanoid:EquipTool(targetTool)
      Rayfield:Notify({ Title = "หยิบสำเร็จ", Content = "หยิบไอเท็ม: " .. targetName .. " แล้ว!", Duration = 2 })
   else
      Rayfield:Notify({ Title = "แจ้งเตือน", Content = "ไอเท็มนี้อาจจะถืออยู่แล้ว", Duration = 2 })
   end
end

