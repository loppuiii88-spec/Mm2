-- ==========================================
-- ลูปการทำงานหลัก (Auto Farm, Noclip, Full Bright & ESP + HP)
-- ==========================================
RunService.Stepped:Connect(function()
	pcall(function()
		-- ระบบ Full Bright
		if isFullBrightEnabled then
			Lighting.Brightness = 2
			Lighting.ClockTime = 12
			Lighting.FogEnd = 100000
			Lighting.GlobalShadows = false
			Lighting.OutdoorAmbient = Color3.fromRGB(255, 255, 255)
		end
		
		-- ระบบมองหา NPC ศัตรู + แสดงชื่อและเลือด
		if isESPEnabled then
			local enemiesFolder = Workspace:FindFirstChild("Enemies") or Workspace
			local activeNPCs = {}
			
			for _, v in ipairs(enemiesFolder:GetChildren()) do
				if v:IsA("Model") and v ~= LocalPlayer.Character then
					local humanoid = v:FindFirstChildOfClass("Humanoid")
					local head = v:FindFirstChild("Head") or v:FindFirstChild("HumanoidRootPart")
					
					if humanoid and head and humanoid.Health > 0 then
						local isPlayer = Players:GetPlayerFromCharacter(v)
						if not isPlayer then
							activeNPCs[v] = true
							
							if not espHighlights[v] then
								local highlight = Instance.new("Highlight")
								highlight.Adornee = v
								highlight.FillColor = Color3.fromRGB(255, 0, 0)
								highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
								highlight.FillTransparency = 0.5
								highlight.OutlineTransparency = 0
								highlight.Parent = v
								espHighlights[v] = highlight
							end
							
							local textLabel = nil
							if not espBillboards[v] then
								local billboard = Instance.new("BillboardGui")
								billboard.Name = "ESPTag"
								billboard.Adornee = head
								billboard.Size = UDim2.new(0, 200, 0, 50)
								billboard.StudsOffset = Vector3.new(0, 3, 0)
								billboard.AlwaysOnTop = true
								
								textLabel = Instance.new("TextLabel")
								textLabel.Name = "InfoText"
								textLabel.Size = UDim2.new(1, 0, 1, 0)
								textLabel.BackgroundTransparency = 1
								textLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
								textLabel.TextStrokeTransparency = 0
								textLabel.TextSize = 14
								textLabel.Font = Enum.Font.SourceSansBold
								textLabel.Parent = billboard
								
								billboard.Parent = head
								espBillboards[v] = billboard
							else
								local billboard = espBillboards[v]
								if billboard and billboard:FindFirstChild("InfoText") then
									textLabel = billboard.InfoText
								end
							end
							
							if textLabel then
								local hp = math.floor(humanoid.Health)
								local maxHp = math.floor(humanoid.MaxHealth)
								textLabel.Text = v.Name .. "\n[HP: " .. hp .. " / " .. maxHp .. "]"
							end
						end
					end
				end
			end
			
			for v, hl in pairs(espHighlights) do
				if not activeNPCs[v] then
					if hl then hl:Destroy() end
					espHighlights[v] = nil
					if espBillboards[v] then
						espBillboards[v]:Destroy()
						espBillboards[v] = nil
					end
				end
			end
		else
			for k, hl in pairs(espHighlights) do
				if hl then hl:Destroy() end
				espHighlights[k] = nil
			end
			for k, bb in pairs(espBillboards) do
				if bb then bb:Destroy() end
				espBillboards[k] = nil
			end
		end
		
		local character = LocalPlayer.Character
		if not character then return end
		
		if isNoclipEnabled then
			for _, part in ipairs(character:GetDescendants()) do
				if part:IsA("BasePart") then part.CanCollide = false end
			end
		end
		
		if isAutoFarmEnabled then
			local hrp = character:FindFirstChild("HumanoidRootPart")
			local humanoid = character:FindFirstChildOfClass("Humanoid")
			
			if hrp and humanoid then
				local targetNPC = getNearestNPC()
				if targetNPC then
					local npcRoot = targetNPC:FindFirstChild("HumanoidRootPart") or targetNPC:FindFirstChild("Head")
					if npcRoot then
						for _, part in ipairs(character:GetDescendants()) do
							if part:IsA("BasePart") then part.CanCollide = false end
						end
						
						local npcPos = npcRoot.Position
						-- ปรับความลึกเป็น -6.5 ตามต้องการ
						hrp.CFrame = CFrame.new(npcPos.X, npcPos.Y - 6.5, npcPos.Z) * CFrame.Angles(math.rad(90), 0, 0)
						hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
						hrp.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
						humanoid.PlatformStand = true
					end
				else
					humanoid.PlatformStand = false
					if not isNoclipEnabled then
						for _, part in ipairs(character:GetDescendants()) do
							if part:IsA("BasePart") then part.CanCollide = true end
						end
					end
				end
			end
		end
	end)
end)
