                if v ~= lp and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                    local knife = v.Backpack:FindFirstChild("Knife") or v.Character:FindFirstChild("Knife")
                    local gun = v.Backpack:FindFirstChild("Gun") or v.Character:FindFirstChild("Gun")
                    
                    local showEsp = false
                    local espColor = Color3.fromRGB(255, 255, 255)
                    
                    if knife and State.EspM then
                        showEsp = true espColor = Color3.fromRGB(255, 0, 0)
                    elseif gun and State.EspS then
                        showEsp = true espColor = Color3.fromRGB(0, 162, 255)
                    elseif not knife and not gun and State.EspI then
                        showEsp = true espColor = Color3.fromRGB(0, 255, 0)
                    end
                    
                    if showEsp then
                        local highlight = v.Character:FindFirstChild("HubHighlight") or Instance.new("Highlight")
                        highlight.Name = "HubHighlight"
                        highlight.Parent = v.Character
                        highlight.FillColor = espColor
                        highlight.FillTransparency = 0.4
                        highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                    else
                        if v.Character:FindFirstChild("HubHighlight") then v.Character.HubHighlight:Destroy() end
                    end
                end
            end
            
            if State.EspG then
                for _, g in pairs(workspace:GetDescendants()) do
                    if g.Name == "GunDrop" then
                        local gh = g:FindFirstChild("GunHighlight") or Instance.new("Highlight")
                        gh.Name = "GunHighlight"
                        gh.Parent = g
                        gh.FillColor = Color3.fromRGB(255, 255, 0)
                        gh.FillTransparency = 0.3
                        gh.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                    end
                end
            end
        end)
    end
end)
