-- 4. ระบบจำลองตรวจสอบสถานะและประมวลผล Auto Coin / Emote / Combat / Auto Grab Gun
task.spawn(function()
    while true do
        pcall(function()
            if State.AutoGrab and lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
                for _, v in pairs(workspace:GetDescendants()) do
                    if v.Name == "GunDrop" or (v:IsA("Part") and v:FindFirstChild("Gun") and v.Parent.Name == "Temp") then
                        lp.Character.HumanoidRootPart.CFrame = v.CFrame
                        break
                    end
                end
            end

            if State.KnifeAura and lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
                local knife = lp.Character:FindFirstChild("Knife") or lp.Backpack:FindFirstChild("Knife")
                if knife then
                    for _, p in pairs(game.Players:GetPlayers()) do
                        if p ~= lp and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                            local targetHRP = p.Character.HumanoidRootPart
                            local distance = (targetHRP.Position - lp.Character.HumanoidRootPart.Position).Magnitude
                            if distance <= State.AuraRange then
                                if knife.Parent == lp.Backpack then knife.Parent = lp.Character end
                                knife:Activate()
                            end
                        end
                    end
                end
            end

            if State.AutoCoin and lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
                for _, v in pairs(workspace:GetDescendants()) do
                    if v.Name == "Coin" or v.Name == "CoinClip" then
                        v.CFrame = lp.Character.HumanoidRootPart.CFrame
                        if State.Instant then task.wait() else task.wait(0.1) end
                    end
                end
            end
            
            if State.EmoteSpam and game:GetService("ReplicatedStorage"):FindFirstChild("PlayEmote") then
                game:GetService("ReplicatedStorage").PlayEmote:FireServer(State.EmoteType)
            end
            
            if State.AutoRespawn and lp.Character and lp.Character:FindFirstChildOfClass("Humanoid") then
                if lp.Character:FindFirstChildOfClass("Humanoid").Health <= 0 then
                    task.wait(2) lp.Character:BreakJoints()
                end
            end
        end)
        task.wait(0.3)
    end
end)

