-- สถานะการทำงานของระบบ
local isScanning = false
local scannedItems = {}

-- ฟังก์ชันดึงพิกัดที่แท้จริงของไอเทม (Support ทั้ง Tool, Part และ Model)
local function getObjectPosition(obj)
    if obj:IsA("Tool") then
        local handle = obj:FindFirstChild("Handle") or obj:FindFirstChildOfClass("Part") or obj:FindFirstChildOfClass("MeshPart")
        if handle then return handle.Position end
    elseif obj:IsA("Model") then
        local primary = obj.PrimaryPart or obj:FindFirstChildOfClass("Part") or obj:FindFirstChildOfClass("MeshPart")
        if primary then return primary.Position end
    elseif obj:IsA("Part") or obj:IsA("MeshPart") then
        return obj.Position
    end
    return nil
end

-- ฟังก์ชันล้างรายการเก่าใน UI
local function clearList()
    for _, child in ipairs(scrollFrame:GetChildren()) do
        if child:IsA("TextButton") then
            child:Destroy()
        end
    end
    table.clear(scannedItems)
end

-- ฟังก์ชันเทเลพอร์ตตัวละคร (Client-Side Teleport)
local function teleportTo(position)
    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if hrp and position then
        -- ยกความสูงขึ้นเล็กน้อยเพื่อเลี่ยงการติดบั๊กใต้พื้นดิน
        hrp.CFrame = CFrame.new(position + Vector3.new(0, 3, 0))
    end
end

-- ฟังก์ชันสแกนหาไอเทมทั่วทั้ง Workspace
local function scanWorkspace()
    if not isScanning then return end
    
    clearList()
    
    -- ลูปค้นหาวัตถุที่เป็นไปได้ใน Workspace (รวมถึง Tool ที่ตกอยู่ และโมเดลที่มีคำเฉพาะเจาะจง)
    for _, obj in ipairs(workspace:GetDescendants()) do
        -- คัดกรองเฉพาะ Tool ที่ไม่ได้ถูกสวมใส่โดยผู้เล่นอื่น หรือวัตถุ Part/Model ที่ไม่ใช่โครงสร้างแมพ
        local isItem = false
        local displayName = obj.Name

        if obj:IsA("Tool") and not obj:FindFirstAncestorOfClass("Model"):FindFirstChildOfClass("Humanoid") then
            isItem = true
        elseif obj:IsA("Model") and (obj:FindFirstChild("Handle") or obj.Name:lower():find("gun") or obj.Name:lower():find("item") or obj.Name:lower():find("weapon")) then
            isItem = true
        end

        if isItem then
            local pos = getObjectPosition(obj)
            if pos then
                table.insert(scannedItems, {Object = obj, Position = pos})
                
                -- สร้างปุ่มแสดงผลบน UI สำหรับไอเทมแต่ละชิ้น
                local itemButton = Instance.new("TextButton")
                itemButton.Size = UDim2.new(1, -10, 0, 35)
                itemButton.BackgroundColor3 = Color3.fromRGB(45, 45, 50)
                itemButton.Text = "  📍 " .. displayName
                itemButton.TextColor3 = Color3.fromRGB(240, 240, 240)
                itemButton.TextSize = 14
                itemButton.TextXAlignment = Enum.TextXAlignment.Left
                itemButton.Font = Enum.Font.SourceSans
                itemButton.Parent = scrollFrame
                
                local btnCorner = Instance.new("UICorner")
                btnCorner.CornerRadius = UDim.new(0, 6)
                btnCorner.Parent = itemButton
                
                -- เมื่อคลิกชื่อไอเทม -> ทำการวาร์ปทันที
                itemButton.MouseButton1Click:Connect(function()
                    teleportTo(pos)
                end)
            end
        end
    end
end

-- การทำงานของสวิตช์เปิด/ปิด (Toggle Logic)
toggleButton.MouseButton1Click:Connect(function()
    isScanning = not isScanning
    if isScanning then
        toggleButton.Text = "SCANNER: ACTIVE"
        toggleButton.BackgroundColor3 = Color3.fromRGB(50, 180, 50)
        scanWorkspace()
    else
        toggleButton.Text = "SCANNER: OFF"
        toggleButton.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
        clearList()
    end
end)

