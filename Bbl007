-- [ CUSTOM PRESTIGE NOTIFICATION ] - ระบบแจ้งเตือน 2 ภาษา
local function SendPremiumNotify(title, text, duration)
    pcall(function()
        local notifyGui = Instance.new("ScreenGui", game:GetService("CoreGui"))
        notifyGui.Name = "NightHubNotify"
        
        local frame = Instance.new("Frame", notifyGui)
        frame.Size = UDim2.new(0, 310, 0, 85)
        frame.Position = UDim2.new(1, 300, 0, 50)
        frame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
        frame.BorderSizePixel = 0
        
        local round = Instance.new("UICorner", frame) round.CornerRadius = UDim.new(0, 10)
        local stroke = Instance.new("UIStroke", frame) stroke.Thickness = 2.5 stroke.Color = Color3.fromRGB(0, 162, 255)
        
        local tLabel = Instance.new("TextLabel", frame)
        tLabel.Size = UDim2.new(1, -20, 0, 25) tLabel.Position = UDim2.new(0, 12, 0, 6) tLabel.BackgroundTransparency = 1
        tLabel.Text = "🔱 " .. title tLabel.TextColor3 = Color3.fromRGB(255, 215, 0) tLabel.TextSize = 13 tLabel.Font = Enum.Font.GothamBold tLabel.TextXAlignment = Enum.TextXAlignment.Left
        
        local descLabel = Instance.new("TextLabel", frame)
        descLabel.Size = UDim2.new(1, -20, 0, 45) descLabel.Position = UDim2.new(0, 12, 0, 32) descLabel.BackgroundTransparency = 1
        descLabel.Text = text descLabel.TextColor3 = Color3.fromRGB(200, 200, 200) descLabel.TextSize = 11 descLabel.Font = Enum.Font.Gotham descLabel.TextWrapped = true descLabel.TextXAlignment = Enum.TextXAlignment.Left

        task.spawn(function()
            local h = 0
            while frame and frame.Parent do task.wait(0.01)
                h = h + 0.006 if h > 1 then h = 0 end
                stroke.Color = Color3.fromHSV(h, 1, 1)
            end
        end)
        
        frame:TweenPosition(UDim2.new(1, -330, 0, 50), "Out", "Back", 0.4, true)
        task.wait(duration or 4)
        frame:TweenPosition(UDim2.new(1, 300, 0, 50), "In", "Linear", 0.3, true, function() notifyGui:Destroy() end)
    end)
end

