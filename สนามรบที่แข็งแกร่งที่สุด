-- ฟังก์ชันปรับร่างให้ "นอนราบแนวนอน" ใต้เท้าศัตรู
local function lockUndergroundHorizontal()
    local myChar = LocalPlayer.Character
    if not myChar or not myChar:FindFirstChild("HumanoidRootPart") then return end
    
    if isUnderground and selectedTargetPlayer and selectedTargetPlayer.Character then
        local targetRoot = selectedTargetPlayer.Character:FindFirstChild("HumanoidRootPart")
        if targetRoot then
            local targetPos = targetRoot.Position
            
            -- ดึง CFrame การหันหน้าปกติของศัตรู
            local targetRotation = targetRoot.CFrame - targetRoot.CFrame.Position
            
            -- คำนวณตำแหน่งจมดินลึก 6.3 studs 
            local newPos = Vector3.new(targetPos.X, targetPos.Y - undergroundOffset, targetPos.Z)
            
            -- หมุนตัวเราในแกน X เป็น 90 องศา (math.rad(90)) เพื่อให้โมเดลนอนราบลงไปกับพื้นโลก (แนวนอน)
            local pitchRotation = CFrame.Angles(math.rad(90), 0, 0)
            
            -- ประกอบตำแหน่ง + การหันหน้าตามศัตรู + ท่านอนราบ
            myChar.HumanoidRootPart.CFrame = CFrame.new(newPos) * targetRotation * pitchRotation
            myChar.HumanoidRootPart.Velocity = Vector3.new(0, 0, 0)
        end
    end
end

-- ฟังก์ชันล็อกตำแหน่งติดหนึบหน้าศัตรู (สกิล 4)
local function lockFrontFollow()
    local myChar = LocalPlayer.Character
    if not myChar or not myChar:FindFirstChild("HumanoidRootPart") then return end
    
    if isStickyFollowing and selectedTargetPlayer and selectedTargetPlayer.Character then
        local targetRoot = selectedTargetPlayer.Character:FindFirstChild("HumanoidRootPart")
        if targetRoot then
            myChar.HumanoidRootPart.CFrame = targetRoot.CFrame * CFrame.new(0, 0, -4.5)
            myChar.HumanoidRootPart.Velocity = Vector3.new(0, 0, 0)
        end
    end
end

-- ฟังก์ชันจัดการปรับเปลี่ยนความโปร่งแสงของวัตถุ (X-Ray Control)
local function applyXrayOpacity(part)
    if part:IsA("BasePart") and not part:IsDescendantOf(LocalPlayer.Character) then
        if part.Name ~= "HumanoidRootPart" then
            if isXrayActive then
                part.LocalTransparencyModifier = 0.6 -- โปร่งแสง 60% มองทะลุเหมือนวิญญาณ
            else
                part.LocalTransparencyModifier = 0 -- กลับมาทึบปกติ
            end
        end
    end
end

-- รีเฟรช X-Ray ทั้งแผนที่
local function refreshMapXray()
    for _, obj in pairs(Workspace:GetDescendants()) do
        applyXrayOpacity(obj)
    end
end

-- อัปเดตรายชื่อในเมนูสแกนเนอร์
local function updatePlayerList()
    for _, child in ipairs(PlayerListFrame:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local pBtn = Instance.new("TextButton")
            pBtn.Size = UDim2.new(1, 0, 0, 35)
            
            if selectedTargetPlayer == player and isUnderground then
                pBtn.BackgroundColor3 = Color3.fromRGB(50, 180, 50)
                pBtn.Text = "🔒 [มุดนอน] " .. player.Name
            else
                pBtn.BackgroundColor3 = Color3.fromRGB(45, 45, 50)
                pBtn.Text = "👤 " .. player.Name
            end
            
            pBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
            pBtn.TextSize = 14
            pBtn.Font = Enum.Font.SourceSansSemibold
            pBtn.Parent = PlayerListFrame
            Instance.new("UICorner", pBtn).CornerRadius = UDim.new(0, 4)
            
            pBtn.MouseButton1Click:Connect(function()
                if isStickyFollowing then
                    isStickyFollowing = false
                    if followConnection then followConnection:Disconnect() end
                    Skill4Btn.BackgroundColor3 = Color3.fromRGB(190, 40, 40)
                    Skill4Btn.Text = "ใช้กับสกิล 4 ของซามูไรเหล็ก"
                end

                if selectedTargetPlayer == player and isUnderground then
                    isUnderground = false
                    selectedTargetPlayer = nil
                    if undergroundConnection then undergroundConnection:Disconnect() end
                else
                    selectedTargetPlayer = player
                    isUnderground = true
                    if undergroundConnection then undergroundConnection:Disconnect() end
                    undergroundConnection = RunService.Heartbeat:Connect(lockUndergroundHorizontal)
                end
                updatePlayerList()
            end)
        end
    end
    PlayerListFrame.CanvasSize = UDim2.new(0, 0, 0, UIListLayout.AbsoluteContentSize.Y)
end

