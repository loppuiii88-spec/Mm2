-- ปุ่มแยกสกิล 4
Skill4Btn.MouseButton1Click:Connect(function()
    local myChar = LocalPlayer.Character
    if not myChar or not myChar:FindFirstChild("HumanoidRootPart") then return end

    if isStickyFollowing then
        isStickyFollowing = false
        if followConnection then followConnection:Disconnect() end
        Skill4Btn.BackgroundColor3 = Color3.fromRGB(190, 40, 40)
        Skill4Btn.Text = "ใช้กับสกิล 4 ของซามูไรเหล็ก"
        return
    end

    if selectedTargetPlayer and selectedTargetPlayer.Character then
        if isUnderground then
            isUnderground = false
            if undergroundConnection then undergroundConnection:Disconnect() end
            updatePlayerList()
        end
        
        task.wait(0.02)
        isStickyFollowing = true
        Skill4Btn.BackgroundColor3 = Color3.fromRGB(200, 150, 0)
        Skill4Btn.Text = "🔒 ล็อกติดหนึบศัตรู (ON)"
        followConnection = RunService.Heartbeat:Connect(lockFrontFollow)
    else
        local originalText = Skill4Btn.Text
        Skill4Btn.Text = "❌ โปรดเลือกเป้าหมายก่อน!"
        task.wait(1.5)
        Skill4Btn.Text = originalText
    end
end)

-- ปุ่มแยก X-RAY (มองทะลุวิญญาณ)
XrayBtn.MouseButton1Click:Connect(function()
    isXrayActive = not isXrayActive
    
    if isXrayActive then
        XrayBtn.BackgroundColor3 = Color3.fromRGB(50, 150, 50) -- สีเขียว (เปิด)
        XrayBtn.Text = "👁️ เปิดใช้งาน X-RAY: ON"
    else
        XrayBtn.BackgroundColor3 = Color3.fromRGB(80, 40, 120) -- สีม่วง (ปิด)
        XrayBtn.Text = "💀 เปิดใช้งาน X-RAY: OFF"
    end
    
    refreshMapXray()
end)

-- ลูปสแกนวัตถุใหม่ที่โหลดเข้าแมพย้อนหลัง (ถ้าเปิด X-Ray ค้างไว้)
Workspace.DescendantAdded:Connect(function(obj)
    if isXrayActive then
        applyXrayOpacity(obj)
    end
end)

-- ปุ่มเปิด/ปิด UI ทั้งหมด
MainToggleBtn.MouseButton1Click:Connect(function()
    uiVisible = not uiVisible
    MainFrame.Visible = uiVisible
    SkillFrame.Visible = uiVisible
    XrayFrame.Visible = uiVisible
    MainToggleBtn.BackgroundColor3 = uiVisible and Color3.fromRGB(50, 50, 60) or Color3.fromRGB(100, 40, 40)
end)

-- ระบบจัดการรายชื่อเมื่อผู้เล่น เข้า-ออก
Players.PlayerAdded:Connect(updatePlayerList)
Players.PlayerRemoving:Connect(function(player)
    if selectedTargetPlayer == player then
        isUnderground = false
        isStickyFollowing = false
        if undergroundConnection then undergroundConnection:Disconnect() end
        if followConnection then followConnection:Disconnect() end
    end
    updatePlayerList()
end)

-- เรียกใช้งานสแกนรายชื่อรอบแรก
updatePlayerList()
